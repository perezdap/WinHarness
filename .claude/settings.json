{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"${CLAUDE_PROJECT_DIR}/.workflow/hooks/gate.ps1\" -Stage pre-tool -AsHook claude"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  }
}
